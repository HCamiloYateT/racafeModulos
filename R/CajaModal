# CajaModal — Modulo Shiny reutilizable ====
# Encapsula un ValueBox (racafe::CajaValor / bs4Dash) con la capacidad de
# abrir un modal al hacer click. El contenido del modal es arbitrario y se
# define desde el modulo padre como una funcion sin argumentos.
#
# Dependencias: shiny, bs4Dash, htmltools, racafe
#
# Helpers exportados:
#   html_valor(v, formato, color, tamano_pct) — valor numerico coloreado
#   html_texto(texto, color, tamano_pct)      — subtitulo coloreado
#
# Uso basico:
#   # UI
#   CajaModalUI("mi_kpi")
#
#   # Server
#   CajaModal(
#     id    = "mi_kpi",
#     valor = reactive(nrow(datos())),
#     texto = "Total clientes",
#     icono = "users",
#     contenido_modal = function() reactable::reactableOutput("mi_tabla")
#   )


## Helpers HTML ----
# Construyen HTML coloreado para valor y subtitulo sin escribir tags a mano.
# IMPORTANTE: color debe pasarse a FormatearNumero (span interior del numero),
# no a FormatearTexto — el span exterior no sobreescribe el color del interior.

html_valor <- function(v, formato = "numero", color = "#212529", tamano_pct = 2) {
  FormatearTexto(
    FormatearNumero(as.numeric(v), formato = formato, color = color),
    tamano_pct = tamano_pct, negrita = TRUE
  )
}
html_texto <- function(texto, color = "#212529", tamano_pct = 1.2) {
  FormatearTexto(texto, tamano_pct = tamano_pct, color = color)
}


## CajaModalUI ----
# UI del modulo. Debe ubicarse en el cuerpo de la UI del padre.
# Incluye tres salidas:
#   - fondo_hex_style : <style> CSS inyectado cuando se usa color_fondo_hex
#   - caja            : bs4ValueBox renderizado por racafe::CajaValor
#   - footer          : parrafo opcional debajo de la caja

CajaModalUI <- function(id) {
  ns <- NS(id)
  tagList(
    uiOutput(ns("fondo_hex_style")),
    bs4Dash::bs4ValueBoxOutput(ns("caja"), width = 12),
    uiOutput(ns("footer"))
  )
}

## CajaModal ----
# Server del modulo.
#
# Parametros:
#   id              - (string)          id del modulo Shiny
#   valor           - (reactive|escalar) numerico | string | shiny.tag | html
#   formato         - (string)          "numero" | "porcentaje" | "moneda"
#                                       Solo aplica cuando valor es numerico.
#   texto           - (reactive|escalar) string | htmltools::HTML() | shiny.tag
#                                       NOTA: racafe::CajaValor exige cadena de
#                                       longitud 1; los shiny.tag se convierten
#                                       automaticamente con htmltools::HTML().
#   icono           - (string)          nombre de icono Font Awesome
#   colores         - (reactive|vector) c(fondo = "token_bs4dash")
#                                       bs4ValueBox solo acepta tokens de color
#                                       bs4Dash (ej: "white", "primary", "info").
#                                       Para hex usar color_fondo_hex.
#   color_fondo_hex - (reactive|string) color hex CSS para el fondo del box.
#                                       Se inyecta como <style> en uiOutput
#                                       separado, ya que renderbs4ValueBox
#                                       exige un shiny.tag puro como retorno.
#                                       NULL = ignorado (default).
#   mostrar_boton   - (logical)         TRUE activa el boton "Ver detalle"
#   contenido_modal - (function|NULL)   function() sin args que retorna la UI
#                                       del modal. Se evalua en el momento del
#                                       click, no al iniciar el modulo.
#   titulo_modal    - (reactive|string) titulo del encabezado del modal
#   icono_modal     - (string)          icono Font Awesome del encabezado
#   tamano_modal    - (string)          "s" | "m" | "l" | "xl" (default "xl")
#   footer          - (reactive|string|NULL) texto debajo de la caja.
#                                       NULL o cadena vacia = sin footer.
#   footer_class    - (string)          clase CSS del parrafo footer.
#                                       Debe estar definida en style.css.
#                                       Default: "caja-modal-footer"

CajaModal <- function(id, valor, formato = "numero", texto = "", icono = "info-circle", 
                      colores = c(fondo = "white"), color_fondo_hex = NULL, mostrar_boton = TRUE,
                      contenido_modal = NULL, titulo_modal = "", icono_modal = "info-circle",
                      tamano_modal = "xl", footer = NULL, footer_class = "caja-modal-footer"
                      ) {
  moduleServer(id, function(input, output, session) {
    ns <- session$ns
    
    # Helpers internos ----
    # Resuelve reactivos y escalares de forma uniforme
    .val <- function(x) if (is.reactive(x)) x() else x
    
    # Convierte shiny.tag/tagList a htmltools::HTML para satisfacer la
    # validacion de CajaValor que exige character de longitud 1
    .normalizar_texto <- function(x) {
      v <- .val(x)
      if (inherits(v, c("shiny.tag", "shiny.tag.list"))) return(htmltools::HTML(as.character(v)))
      v
    }
    
    # CSS fondo hex ----
    # renderbs4ValueBox exige shiny.tag puro — no acepta tagList con <style>.
    # El CSS se inyecta en el DOM via uiOutput independiente con selector
    # escopado al id del output: #ns("caja") .small-box
    output$fondo_hex_style <- renderUI({
      hex <- .val(color_fondo_hex)
      if (is.null(hex) || !nzchar(hex)) return(NULL)
      tags$style(paste0("#", ns("caja"), " .small-box { background-color: ", hex, " !important; }"))
    })
    
    # Render caja ----
    # Delega siempre en racafe::CajaValor. El boton "Ver detalle" solo se
    # activa si mostrar_boton = TRUE y existe contenido_modal definido.
    output$caja <- bs4Dash::renderbs4ValueBox({
      id_boton <- if (isTRUE(mostrar_boton) && !is.null(contenido_modal)) ns("btn_abrir") else NULL
      racafe::CajaValor(valor = .val(valor), formato = formato, texto = .normalizar_texto(texto),
                        icono = icono, inputId = id_boton, 
                        mostrar_boton = isTRUE(mostrar_boton) && !is.null(contenido_modal),
                        colores = .val(colores))
      })
    
    # Render footer ----
    # Retorna NULL si footer es NULL o cadena vacia, evitando espacio en blanco
    output$footer <- renderUI({
      txt <- .val(footer)
      if (is.null(txt) || !nzchar(as.character(txt))) return(NULL)
      p(txt, class = footer_class)
    })
    
    # Apertura modal ----
    # contenido_modal se evalua aqui (no al iniciar) para construir la UI
    # solo cuando el usuario abre el modal. El server del modulo hijo debe
    # estar registrado en el padre antes de que esto ocurra.
    observeEvent(input$btn_abrir, {
      req(!is.null(contenido_modal))
      showModal(
        modalDialog(title = tagList(shiny::icon(icono_modal), " ", .val(titulo_modal)),
                    size = tamano_modal, easyClose = TRUE, footer = modalButton("Cerrar"),
                    contenido_modal()
                    )
        )
    }, ignoreNULL = TRUE, ignoreInit = TRUE)
    
  })
}
